/* generated by matugen — launched via wofi --style ~/.cache/oni/wofi.css */
window {
  background-color: rgba(3, 6, 6, 0.94);
  border: 1px solid alpha({{colors.primary.default.hex}}, 0.25);
  border-radius: 10px;
  font-family: "JetBrainsMono Nerd Font";
  font-size: 12.5px;
}
#input {
  background: transparent; border: none; border-radius: 0;
  border-bottom: 1px solid alpha({{colors.primary.default.hex}}, 0.12);
  padding: 11px 14px; color: #c9d2cf;
}
#entry { padding: 7px 10px; border-radius: 7px; margin: 3px 5px 0; }
#entry:selected { background: alpha({{colors.primary.default.hex}}, 0.12); }
#text { color: #c9d2cf; }
#entry:selected #text { color: {{colors.primary.default.hex}}; }

#!/usr/bin/env bash
# Oni · on-screen keybind cheatsheet (SUPER+K)
# Any key = close · SUPER+K again = hide (keeps running)

M=$'\e[38;2;95;224;192m'   # mint
I=$'\e[38;2;157;184;196m'  # ice
D=$'\e[38;2;102;113;110m'  # dim
W=$'\e[38;2;201;210;207m'  # ink
R=$'\e[0m'
clear
row(){ printf "  ${M}%-18s${R}${W}%s${R}\n" "$1" "$2"; }
hdr(){ printf "\n  ${I}── %s ${D}%s${R}\n" "$1" "──────────────────────────────"; }

printf "\n  ${M}◆ ONI${R} ${D}· keybinds · any key closes${R}\n"

hdr "Apps"
row "SUPER T"          "terminal (kitty)"
row "SUPER E"          "file explorer"
row "SUPER B"          "browser (firefox)"
row "SUPER M"          "proton mail"
row "SUPER A"          "claude"
row "SUPER S"          "steam"
row "SUPER D"          "discord"
row "SUPER Y"          "youtube music"
row "SUPER SPACE"      "app launcher"

hdr "Scratchpads"
row "SUPER ^"          "dropdown terminal (over anything)"
row "SUPER X"          "file explorer overlay (over games!)"

hdr "Workspaces"
row "SUPER 1-3"        "center monitor"
row "SUPER 4-5"        "left  (4 discord · 5 mail)"
row "SUPER 6-7"        "right (6 music · 7 claude)"
row "+ SHIFT"          "move window there"
row "SUPER CTRL ←→"    "jump monitor focus"
row "+ SHIFT"          "throw window across monitors"

hdr "Screenshots & clipboard"
row "PRINT"            "region → file + clipboard"
row "SHIFT PRINT"      "current monitor"
row "SUPER PRINT"      "single window"
row "SUPER SHIFT S"    "region → clipboard only"
row "SUPER V"          "clipboard history"
row "SUPER SHIFT C"    "color picker → clipboard"

hdr "System"
row "SUPER Q"          "close window"
row "SUPER F"          "fullscreen"
row "SUPER SHIFT V"    "toggle floating"
row "SUPER G"          "game mode (animations off)"
row "SUPER L"          "lock"
row "SUPER W"          "toggle desktop widgets"
row "SUPER SHIFT W"    "wallpaper picker (restyles accent)"
row "SUPER K"          "this sheet"
printf "\n"
read -rsn1
